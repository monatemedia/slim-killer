# Slim Killer Core Configuration
APP_NAME="Slim Killer"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database Configuration matrix
# Options: sqlite, mysql, mariadb, pgsql
DB_DRIVER=sqlite
DB_PREFIX=

# SQLite Configuration (Default)
DB_DATABASE=database/database.sqlite

# MySQL / PostgreSQL Settings (Uncomment if needed)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=slim_killer
# DB_USERNAME=root
# DB_PASSWORD=