#!/usr/bin/env php
<?php

declare(strict_types=1);

// Suppress vendor deprecations to keep terminal interfaces immaculate
error_reporting(E_ALL & ~E_DEPRECATED);

use DI\ContainerBuilder;
use App\Infrastructure\Commands\CommandInterface;

require __DIR__ . '/vendor/autoload.php';

// 1. Ingest dynamic environmental variables (.env setup)
require __DIR__ . '/config/bootstrap.php';

// 2. Safely initialize and compile the PHP-DI Container
$containerBuilder = new ContainerBuilder();
$containerBuilder->addDefinitions(__DIR__ . '/config/services.php');
$container = $containerBuilder->build();

// --- Dynamic Auto-Discovery Command Registry ---
$commands = [];
$commandsDir = __DIR__ . '/src/Infrastructure/Commands';
$commandInterface = CommandInterface::class;

if (is_dir($commandsDir)) {
    $directory = new RecursiveDirectoryIterator($commandsDir);
    $iterator = new RecursiveIteratorIterator($directory);
    $regex = new RegexIterator($iterator, '/^.+\.php$/i', RecursiveRegexIterator::GET_MATCH);

    foreach ($regex as $fileInfo) {
        $filePath = $fileInfo[0];
        
        $standardizedPath = str_replace('\\', '/', $filePath);
        $standardizedCommandsDir = str_replace('\\', '/', $commandsDir);

        $relativePath = str_replace([$standardizedCommandsDir, '.php', '/'], ['', '', '\\'], $standardizedPath);
        $className = 'App\\Infrastructure\\Commands' . $relativePath;

        if (class_exists($className)) {
            $reflection = new ReflectionClass($className);
            if ($reflection->isInstantiable() && $reflection->implementsInterface($commandInterface)) {
                $commands[] = $container->get($className);
            }
        }
    }
}

// --- Dynamic Command Execution Engine ---
$commandName = $argv[1] ?? 'help';

if ($commandName === 'help' || $commandName === '-h' || $commandName === '--help') {
    display_banner();
    echo "\e[33mUsage:\e[0m\n";
    echo "  php hammer [command] [options]\n\n";
    echo "\e[33mAvailable commands:\e[0m\n";
    
    // --- ARTISAN-STYLE GROUPING MECHANISM ---
    $groupedCommands = [];
    $rootCommands = [];

    foreach ($commands as $cmd) {
        $signature = $cmd->getName();
        
        // If the command contains a colon (e.g., "make:action"), group it
        if (strpos($signature, ':') !== false) {
            [$group, $subCommand] = explode(':', $signature, 2);
            $groupedCommands[$group][] = $cmd;
        } else {
            // Root-level global commands (e.g., "serve", "migrate")
            $rootCommands[] = $cmd;
        }
    }

    // Sort groups and root commands alphabetically
    ksort($groupedCommands);
    usort($rootCommands, fn($a, $b) => strcmp($a->getName(), $b->getName()));

    // 1. Render Root/Global Commands First
    foreach ($rootCommands as $cmd) {
        printf("  \e[32m%-25s\e[0m %s\n", $cmd->getName(), $cmd->getDescription());
    }

    // 2. Render Namespace-Grouped Sections Safely
    foreach ($groupedCommands as $group => $subCmds) {
        echo "\n \e[1;33m" . $group . "\e[0m\n"; // Bold Yellow Group Header
        
        // Sort subcommands inside their group container
        usort($subCmds, fn($a, $b) => strcmp($a->getName(), $b->getName()));
        
        foreach ($subCmds as $cmd) {
            printf("  \e[32m%-25s\e[0m %s\n", $cmd->getName(), $cmd->getDescription());
        }
    }
    echo "\n";
    exit(0);
}

foreach ($commands as $cmd) {
    if ($cmd->getName() === $commandName) {
        $cmd->handle($argv);
        exit(0);
    }
}

echo "\e[31m[ERROR] Unknown command signature:\e[0m '$commandName'. Run 'php hammer help'.\n";
exit(1);

function display_banner(): void { 
    echo "\e[33m"; 
    echo "  _   _                                      \n"; 
    echo " | | | | __ _ _ __ ___  _ __ ___   ___ _ __ \n"; 
    echo " | |_| |/ _` | '_ ` _ \| '_ ` _ \ / _ \ '__|\n"; 
    echo " |  _  | (_| | | | | | | | | | | |  __/ |   \n"; 
    echo " |_| |_|\__,_|_| |_| |_|_| |_| |_|\___|_|   \n"; 
    echo "        SLIM-KILLER CLI RUNTIME KERNEL     \n"; 
    echo "\e[0m\n"; 
}