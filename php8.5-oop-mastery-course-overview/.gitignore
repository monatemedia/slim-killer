# PHP 8.5 OOP Mastery Course — .gitignore

# ── Composer ──────────────────────────────────────────────
/vendor/
composer.lock

# ── PHP-DI compiled container cache ───────────────────────
/var/
/cache/
**/var/cache/

# ── PHPUnit ───────────────────────────────────────────────
/.phpunit.cache/
/.phpunit.result.cache
/coverage/
/build/

# ── Environment / secrets ─────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── OS files ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.phpstorm.meta.php
_ide_helper.php

# ── Logs ──────────────────────────────────────────────────
*.log
/logs/
/tmp/

# ── Node (if any tooling added later) ─────────────────────
node_modules/
npm-debug.log
yarn-error.log

# ── Slim PHP uploaded files / storage ─────────────────────
/public/uploads/
/storage/

# ── Course-specific: never commit generated test artefacts ─
**/tests/coverage/
**/tests/.phpunit.result.cache

prompt.md